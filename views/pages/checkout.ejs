<div class="container">
  <h1 style="padding-top: 32px;">Checkout</h1>

  <!-- Validation Errors -->
  <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
    <div class="flash-message flash-error" style="margin-bottom: 24px;">
      <div>
        <% errors.forEach(function(e) { %>
          <p style="margin-bottom: 4px;"><%= e %></p>
        <% }); %>
      </div>
    </div>
  <% } %>

  <!-- Prescription Upload Section -->
  <% if (typeof hasRxItems !== 'undefined' && hasRxItems) { %>
    <div class="prescription-section">
      <h3>&#9877; Prescription Required</h3>
      <p>The following items in your cart require a valid prescription:</p>
      <ul class="rx-items-list">
        <% if (typeof cart !== 'undefined' && cart) { %>
          <% cart.forEach(function(item) { %>
            <% if (item.requiresPrescription) { %>
              <li>&#8226; <%= item.title %></li>
            <% } %>
          <% }); %>
        <% } %>
      </ul>
      <div class="prescription-upload">
        <label class="form-label" for="prescription"><strong>Upload your prescription (photo or scan) *</strong></label>
        <input
          type="file"
          id="prescription"
          name="prescription"
          accept=".jpg,.jpeg,.png,.pdf"
          required
          form="checkoutForm"
        >
        <p class="prescription-note">Your prescription will be verified by our licensed pharmacist before your order is dispatched.</p>
      </div>
    </div>
  <% } %>

  <div class="checkout-layout">
    <!-- Checkout Form -->
    <div class="checkout-form">
      <h2>Delivery Details</h2>
      <form action="/checkout" method="POST" id="checkoutForm" enctype="multipart/form-data">
        <div class="checkout-section">
          <h3>Contact Information</h3>

          <div class="form-group">
            <label class="form-label" for="name">Full Name *</label>
            <input
              type="text"
              id="name"
              name="name"
              class="form-input"
              value="<%= (typeof formData !== 'undefined' && formData) ? formData.name || '' : '' %>"
              required
              placeholder="John Doe"
            >
          </div>

          <div class="form-group">
            <label class="form-label" for="phone">Phone Number *</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="form-input"
              value="<%= (typeof formData !== 'undefined' && formData) ? formData.phone || '' : '' %>"
              required
              placeholder="+254 7XX XXX XXX"
            >
          </div>

          <div class="form-group">
            <label class="form-label" for="email">Email Address *</label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              value="<%= (typeof formData !== 'undefined' && formData) ? formData.email || '' : '' %>"
              required
              placeholder="you@example.com"
            >
          </div>
        </div>

        <div class="checkout-section">
          <h3>Delivery Address</h3>

          <div class="form-group">
            <label class="form-label" for="address">Address *</label>
            <textarea
              id="address"
              name="address"
              class="form-textarea"
              required
              placeholder="Enter your full delivery address including building, street, and area"
            ><%= (typeof formData !== 'undefined' && formData) ? formData.address || '' : '' %></textarea>
          </div>
        </div>

        <button type="submit" class="btn btn-primary btn-lg btn-block">
          Place Order
        </button>
      </form>
    </div>

    <!-- Order Summary Sidebar -->
    <div class="checkout-summary">
      <h3>Order Summary</h3>

      <% if (typeof cart !== 'undefined' && cart) { %>
        <% cart.forEach(function(item) { %>
          <div class="checkout-summary-item">
            <span class="item-name"><%= item.title %></span>
            <span class="item-qty">x<%= item.quantity %></span>
            <span class="item-price">KES <%= Number(item.price * item.quantity).toLocaleString() %></span>
          </div>
        <% }); %>
      <% } %>

      <div class="cart-summary-row" style="border-top: 1px solid #E2E8F0; padding-top: 12px; margin-top: 12px;">
        <span>Delivery</span>
        <span><%= total >= 2500 ? 'Free' : 'Calculated at delivery' %></span>
      </div>

      <div class="cart-summary-row total">
        <span>Total</span>
        <span>KES <%= Number(total).toLocaleString() %></span>
      </div>

      <div class="cart-delivery-note">
        &#128666; Free delivery on orders above KES 2,500
      </div>
    </div>
  </div>
</div>
