<div class="container">
  <div class="search-results-header">
    <h1>
      Search Results
      <% if (typeof query !== 'undefined' && query) { %>
        for: <span class="search-query">"<%= query %>"</span>
      <% } %>
    </h1>
    <p class="search-count"><%= total %> result<%= total !== 1 ? 's' : '' %> found</p>
  </div>

  <% if (products && products.length > 0) { %>
    <div class="product-grid">
      <% products.forEach(function(p) { %>
        <%- include('../partials/product-card', { product: p }) %>
      <% }); %>
    </div>

    <% if (totalPages > 1) { %>
      <%- include('../partials/pagination', {
        page: page,
        totalPages: totalPages,
        baseUrl: '/search',
        query: { q: query }
      }) %>
    <% } %>
  <% } else { %>
    <div class="no-results">
      <div style="font-size: 4rem; margin-bottom: 16px; opacity: 0.3;">&#128269;</div>
      <h2>No products found</h2>
      <p>We couldn't find any products matching your search. Try different keywords or browse our categories.</p>

      <div style="margin-top: 24px;">
        <p style="font-size: 0.875rem; color: #94A3B8; margin-bottom: 12px;">Suggestions:</p>
        <ul style="font-size: 0.875rem; color: #5A6B7B; display: inline-block; text-align: left;">
          <li>&#8226; Check your spelling</li>
          <li>&#8226; Try more general keywords</li>
          <li>&#8226; Try different keywords</li>
        </ul>
      </div>

      <div style="margin-top: 32px;">
        <a href="/" class="btn btn-primary">Browse Categories</a>
      </div>
    </div>
  <% } %>
</div>
