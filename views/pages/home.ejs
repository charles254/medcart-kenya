<!-- Hero Banner Slideshow -->
<section class="hero-slider" id="heroSlider">
  <div class="slider-track" id="sliderTrack">

    <!-- Slide 1: Main -->
    <div class="slide slide-active" style="background: linear-gradient(135deg, #00A651 0%, #005C2E 100%);">
      <div class="container slide-inner">
        <div class="slide-content">
          <span class="slide-badge">Kenya's #1 Online Pharmacy</span>
          <h1>Your Health &amp; Wellness,<br>Delivered to Your Door</h1>
          <p>Shop over 8,000+ medicines, supplements, and health products from trusted brands with fast delivery across Kenya.</p>
          <a href="/category/health-and-wellness" class="slide-btn">Shop Now</a>
        </div>
        <div class="slide-image">
          <img src="/images/banners/slide1.svg" alt="AfyaCart Online Pharmacy" loading="eager">
        </div>
      </div>
    </div>

    <!-- Slide 2: Vitamins -->
    <div class="slide" style="background: linear-gradient(135deg, #1B3A5C 0%, #0D1F33 100%);">
      <div class="container slide-inner">
        <div class="slide-content">
          <span class="slide-badge" style="background: rgba(74,222,128,0.2); border-color: rgba(74,222,128,0.3);">Boost Your Immunity</span>
          <h2>Vitamins &amp; Supplements<br>For the Whole Family</h2>
          <p>From Vitamin C to Omega-3, find all the supplements you need to stay healthy and energized.</p>
          <a href="/category/vitamins-and-supplements" class="slide-btn" style="background: #006432; color: white;">Shop Vitamins</a>
        </div>
        <div class="slide-image">
          <img src="/images/banners/slide2.svg" alt="Vitamins and Supplements" loading="lazy">
        </div>
      </div>
    </div>

    <!-- Slide 3: Deals -->
    <div class="slide" style="background: linear-gradient(135deg, #FF6B35 0%, #CC4400 100%);">
      <div class="container slide-inner">
        <div class="slide-content">
          <span class="slide-badge" style="background: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.3);">Limited Time Offer</span>
          <h2>Mega Sale!<br>Up to 50% Off</h2>
          <p>Huge discounts on health essentials, beauty products, and wellness items. Don't miss out!</p>
          <a href="/deals" class="slide-btn" style="background: white; color: #FF6B35;">Shop Deals</a>
        </div>
        <div class="slide-image">
          <img src="/images/banners/slide3.svg" alt="Sale and Offers" loading="lazy">
        </div>
      </div>
    </div>

  </div>

  <!-- Slider Controls -->
  <button class="slider-arrow slider-prev" id="sliderPrev" aria-label="Previous slide">&#10094;</button>
  <button class="slider-arrow slider-next" id="sliderNext" aria-label="Next slide">&#10095;</button>

  <!-- Dots -->
  <div class="slider-dots" id="sliderDots">
    <button class="slider-dot active" data-slide="0" aria-label="Go to slide 1"></button>
    <button class="slider-dot" data-slide="1" aria-label="Go to slide 2"></button>
    <button class="slider-dot" data-slide="2" aria-label="Go to slide 3"></button>
  </div>
</section>

