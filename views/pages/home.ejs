<!-- Category Grid -->
<section class="section">
  <div class="container">
    <div class="section-header">
      <h2>Shop by Category</h2>
    </div>

    <div class="category-grid">
      <% categories.forEach(function(cat) { %>
        <a href="/category/<%= cat.slug %>" class="category-card">
          <div class="category-card-icon"><%- cat.icon || '&#128138;' %></div>
          <div class="category-card-name"><%= cat.name %></div>
          <div class="category-card-count"><%= cat.product_count || 0 %> products</div>
        </a>
      <% }); %>
    </div>
  </div>
</section>

<!-- Trending Products -->
<section class="section" >
  <div class="container">
    <div class="section-header">
      <h2>Popular Products</h2>
      <a href="/deals">View All &rarr;</a>
    </div>

    <div class="product-grid">
      <% trending.forEach(function(p) { %>
        <%- include('../partials/product-card', { product: p }) %>
      <% }); %>
    </div>
  </div>
</section>

<!-- Deals Section -->
<% if (deals && deals.length > 0) { %>
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>&#128293; Today's Deals</h2>
        <a href="/deals">See All Deals &rarr;</a>
      </div>

      <div class="product-grid">
        <% deals.forEach(function(p) { %>
          <%- include('../partials/product-card', { product: p }) %>
        <% }); %>
      </div>
    </div>
  </section>
<% } %>

<!-- Popular Brands -->
<% if (popularBrands && popularBrands.length > 0) { %>
  <section class="section brands-section">
    <div class="container">
      <div class="section-header">
        <h2>Popular Brands</h2>
        <a href="/brands">View All Brands &rarr;</a>
      </div>

      <div class="brands-grid">
        <%
          var brandColors = ['#00A651','#1B3A5C','#FF6B35','#8B5CF6','#EC4899','#0EA5E9','#F59E0B','#10B981','#EF4444','#6366F1','#14B8A6','#F97316'];
          popularBrands.forEach(function(b, i) {
            var color = brandColors[i % brandColors.length];
            var initial = (b.name || '?').charAt(0).toUpperCase();
        %>
          <a href="/brand/<%= b.slug %>" class="brand-card-new">
            <div class="brand-avatar" style="background: <%= color %>;">
              <span><%= initial %></span>
            </div>
            <div class="brand-info">
              <div class="brand-card-name"><%= b.name %></div>
              <div class="brand-card-count"><%= b.product_count || 0 %> products</div>
            </div>
          </a>
        <% }); %>
      </div>
    </div>
  </section>
<% } %>
