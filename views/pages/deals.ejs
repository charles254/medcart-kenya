<div class="container">
  <!-- Deals Banner -->
  <div class="deals-header">
    <h1>&#128293; Today's Deals &amp; Offers</h1>
    <p>Save big on health products, medicines, and more!</p>
  </div>

  <p class="text-muted mb-6"><%= total %> deal<%= total !== 1 ? 's' : '' %> available</p>

  <% if (products && products.length > 0) { %>
    <div class="product-grid">
      <% products.forEach(function(p) { %>
        <%- include('../partials/product-card', { product: p }) %>
      <% }); %>
    </div>

    <% if (totalPages > 1) { %>
      <%- include('../partials/pagination', {
        page: page,
        totalPages: totalPages,
        baseUrl: '/deals',
        query: {}
      }) %>
    <% } %>
  <% } else { %>
    <div class="no-results">
      <h2>No deals at the moment</h2>
      <p>Check back later for new deals and offers.</p>
      <a href="/" class="btn btn-primary">Browse Products</a>
    </div>
  <% } %>
</div>
