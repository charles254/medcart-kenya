<div class="container">
  <div class="error-page">
    <div class="error-code">404</div>
    <h1>Page Not Found</h1>
    <p>The page you're looking for doesn't exist or has been moved. Try searching for what you need.</p>

    <form action="/search" method="GET" class="search-bar" style="max-width: 400px; margin: 0 auto 24px;">
      <input type="text" name="q" placeholder="Search for products..." autocomplete="off">
      <button type="submit" aria-label="Search">&#128269;</button>
    </form>

    <a href="/" class="btn btn-primary">Go Home</a>
  </div>
</div>
