<div class="container">
  <div class="checkout-success">
    <!-- Green Checkmark -->
    <div class="success-icon">&#10003;</div>

    <h1>Order Placed Successfully!</h1>

    <% if (typeof order !== 'undefined' && order) { %>
      <p>Thank you, <strong><%= order.customer.name %></strong>! Your order has been placed successfully.</p>

      <div class="order-summary-card">
        <h3 style="margin-bottom: 16px;">Order Details</h3>

        <% if (order.items) { %>
          <% order.items.forEach(function(item) { %>
            <div class="checkout-summary-item">
              <span class="item-name"><%= item.title %></span>
              <span class="item-qty">x<%= item.quantity %></span>
              <span class="item-price">KES <%= Number(item.price * item.quantity).toLocaleString() %></span>
            </div>
          <% }); %>
        <% } %>

        <div class="cart-summary-row total">
          <span>Total</span>
          <span>KES <%= Number(order.total).toLocaleString() %></span>
        </div>

        <% if (order.prescriptionFile) { %>
          <div style="margin-top: 16px; padding: 12px; background: #F0FDF4; border: 1px solid #BBF7D0; border-radius: 8px;">
            <p style="margin: 0; color: #166534; font-size: 0.875rem;">
              &#9877; <strong>Prescription uploaded successfully.</strong> Your prescription will be reviewed by our licensed pharmacist before your order is dispatched.
            </p>
          </div>
        <% } %>

        <div style="margin-top: 16px; font-size: 0.875rem; color: #5A6B7B;">
          <p style="margin-bottom: 4px;">A confirmation will be sent to <strong><%= order.customer.email %></strong></p>
          <p style="margin-bottom: 0;">We will contact you at <strong><%= order.customer.phone %></strong> for delivery coordination.</p>
        </div>
      </div>
    <% } else { %>
      <p>Your order has been placed successfully. Thank you for shopping with AfyaCart!</p>
    <% } %>

    <a href="/" class="btn btn-primary btn-lg">Continue Shopping</a>
  </div>
</div>
