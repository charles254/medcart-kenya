<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' && title ? title : 'AfyaCart Kenya - Online Pharmacy' %></title>
  <meta name="description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'Shop for medicines, health products, vitamins, and wellness items online at AfyaCart Kenya. Fast delivery across Kenya.' %>">

  <!-- Canonical -->
  <link rel="canonical" href="https://afyacart.net<%= typeof canonicalPath !== 'undefined' ? canonicalPath : '' %>">

  <!-- Robots -->
  <meta name="robots" content="<%= typeof noindex !== 'undefined' && noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1' %>">

  <!-- Open Graph -->
  <meta property="og:type" content="<%= typeof ogType !== 'undefined' ? ogType : 'website' %>">
  <meta property="og:site_name" content="AfyaCart Kenya">
  <meta property="og:title" content="<%= typeof title !== 'undefined' && title ? title : 'AfyaCart Kenya - Online Pharmacy' %>">
  <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'Shop 8,000+ medicines, supplements & health products. Fast delivery across Kenya.' %>">
  <meta property="og:image" content="<%= typeof ogImage !== 'undefined' && ogImage ? ogImage : 'https://afyacart.net/images/og-image.png' %>">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:url" content="https://afyacart.net<%= typeof canonicalPath !== 'undefined' ? canonicalPath : '' %>">
  <meta property="og:locale" content="en_KE">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@afyacart">
  <meta name="twitter:title" content="<%= typeof title !== 'undefined' && title ? title : 'AfyaCart Kenya - Online Pharmacy' %>">
  <meta name="twitter:description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'Shop 8,000+ medicines, supplements & health products. Fast delivery across Kenya.' %>">
  <meta name="twitter:image" content="<%= typeof ogImage !== 'undefined' && ogImage ? ogImage : 'https://afyacart.net/images/og-image.svg' %>">

  <!-- JSON-LD Structured Data -->
  <% if (typeof jsonLd !== 'undefined' && jsonLd) { %>
    <% if (Array.isArray(jsonLd)) { %>
      <% jsonLd.forEach(function(schema) { %>
        <script type="application/ld+json"><%- JSON.stringify(schema) %></script>
      <% }); %>
    <% } else { %>
      <script type="application/ld+json"><%- JSON.stringify(jsonLd) %></script>
    <% } %>
  <% } %>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">

  <!-- Fonts & CSS -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/variables.css">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <!-- Google Analytics: deferred after page load -->
  <script>
    window.addEventListener('load', function() {
      setTimeout(function() {
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-E8BKDVLYND';
        s.async = true;
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', 'G-E8BKDVLYND');
      }, 2000);
    });
  </script>
  <%- include('../partials/header') %>

  <% if (typeof flash !== 'undefined' && flash) { %>
    <div class="container">
      <% if (flash.success) { %>
        <div class="flash-message flash-success">
          <span>&#10003;</span> <%= flash.success %>
        </div>
      <% } %>
      <% if (flash.error) { %>
        <div class="flash-message flash-error">
          <span>&#10007;</span> <%= flash.error %>
        </div>
      <% } %>
    </div>
  <% } %>

  <main>
    <%- body %>
  </main>

  <%- include('../partials/footer') %>

  <!-- WhatsApp Floating Chat Button -->
  <a href="https://wa.me/254734600890?text=Hi%20AfyaCart!%20I%20need%20help%20with%20my%20order." class="whatsapp-float" target="_blank" rel="noopener noreferrer" aria-label="Chat on WhatsApp">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    <span class="whatsapp-float-label">Chat with us</span>
  </a>

  <!-- Social Proof Toast Notifications -->
  <div class="social-proof-container" id="socialProofContainer"></div>

  <script src="/js/main.js" defer></script>
  <script src="/js/search.js" defer></script>
  <script src="/js/cart.js" defer></script>
  <script src="/js/social-proof.js" defer></script>
</body>
</html>
